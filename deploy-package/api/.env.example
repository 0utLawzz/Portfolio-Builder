# =============================================================
# OUTLAWZ LABS™ — API Server Environment Variables
# Copy this to .env and fill in your values
# =============================================================

# --- DATABASE ---
# Get a free PostgreSQL URL from: https://neon.tech (recommended)
# Or: https://supabase.com (free tier)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- SESSION SECRET ---
# Generate a strong random string (32+ chars). Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-minimum-32-characters

# --- ADMIN PASSWORD ---
# Password for the admin panel at /admin
ADMIN_PASSWORD=outlawz2025

# --- SERVER ---
PORT=3000
NODE_ENV=production
